# ──────────────────────────────────────────────────────────────
# Panda Marketing Admin — Environment Variables
# Copy to .env.local and run: node scripts/setup-admin.cjs
# Do NOT commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# Admin login email
VITE_ADMIN_EMAIL=

# bcrypt hash of the admin password (cost factor 10).
# Generate with: npm run setup:admin
# Never store or commit the plaintext password.
VITE_ADMIN_PASSWORD_HASH=
