generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Key-value store for singleton content (home page, about page, site settings)
model SiteContent {
  key       String   @id
  data      String // JSON blob
  updatedAt DateTime @default(now()) @updatedAt
}

model Service {
  id        String   @id
  slug      String   @unique
  active    Boolean  @default(true)
  order     Int      @default(0)
  data      String // JSON of full ServiceItem
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model PortfolioItem {
  id        String   @id
  slug      String   @unique
  category  String   @default("branding")
  featured  Boolean  @default(false)
  active    Boolean  @default(true)
  order     Int      @default(0)
  data      String // JSON of full PortfolioItem
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Testimonial {
  id        String   @id
  active    Boolean  @default(true)
  order     Int      @default(0)
  data      String // JSON of full Testimonial
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Brand {
  id        String   @id
  name      String   @default("")
  active    Boolean  @default(true)
  order     Int      @default(0)
  data      String // JSON of full Brand
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  phone     String   @default("")
  email     String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}
